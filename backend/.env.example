# ==========================================
# Mochi Bot - Backend Environment Variables
# ==========================================

# 1. Server Configuration
# The port your Node.js server will run on
PORT=3000

# 2. Spotify Web API Credentials
# Get these from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# Must exactly match the URI set in your Spotify Developer Dashboard
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback

# 3. OpenWeatherMap API Credentials
# Get this from: https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
# Your city's coordinates (Example below is for Bogura, Bangladesh)
LAT=24.8481
LON=89.3730

# 4. Local AI (Ollama)
# The default local address where Ollama runs its API
OLLAMA_URL=http://127.0.0.1:11434/api/generate